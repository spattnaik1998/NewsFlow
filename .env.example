# Copy this file to .env.local and fill in your keys

# OpenAI — used for batch article summarization and AI categorization fallback
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Serper — Google News search (background aggregation + live search)
# Get yours at: https://serper.dev
SERPER_API_KEY=...

# Tavily — Deep research search (only triggered on user "Deep search" click)
# Get yours at: https://tavily.com
TAVILY_API_KEY=tvly-...
